{

    "layout": {
        "type": "grid",
        "rows": 2,
        "cols": 4,
        "space" : "2mm",
        "rotation": "0deg",
        "alternation": "none",
        "renamenet": "Board_{n}-{orig}",
        "renameref": "{orig}"
    },
    "source": {
        "type": "auto",
        "tolerance": "1mm"
    },
    "tabs": {
        "type": "fixed",
        "width" : "3mm",
        "vcount": 2,
        "source": "none"
    },
    "cuts": {
        "type": "mousebites",
        "drill" : "0.5mm",
        "spacing" : "0.75mm",
        "offset" : "0.2mm",
        "prolong" : "0.5mm"
    },
    "framing": {
        "type": "railstb",
        "width" : "5mm",
        "space" : "2mm"
    },
    "post": {
        "type": "auto",
        "millradius": "1mm",
        "copperfill": false
    }
}
